AWS_REGION=
# AWS named profile from ~/.aws/credentials (defaults to default profile if not set)
AWS_PROFILE=
# Optional: Bearer token for Bedrock (takes precedence over profile-based auth)
# AWS_BEARER_TOKEN_BEDROCK=
