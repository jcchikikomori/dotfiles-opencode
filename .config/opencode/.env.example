# MCP Servers
GITHUB_PERSONAL_ACCESS_TOKEN=
STACK_EXCHANGE_API_KEY=
FIGMA_API_KEY=
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
