{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    "envsitter-guard@latest",
    "oh-my-opencode-slim",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-mem",
    "opencode-redactor@0.1.1"
  ],
  "default_agent": "OpenAgent",
  "permission": {
    "tool": {
      "*": "allow"
    },
    "skill": {
      "*": "allow",
      "git": "allow"
    },
    "bash": {
      "git commit *": "deny",
      "git commit": "deny",
      "git push *": "deny",
      "git push": "deny",
      "git reset --hard *": "deny",
      "git revert *": "ask",
      "rm -rf *": "ask",
      "sudo *": "ask",
      "*": "allow"
    }
  },
  "provider": {
    "github-copilot": {},
    "amazon-bedrock": {
      "options": {
        "region": "{env:AWS_REGION}",
        "profile": "{env:AWS_PROFILE}"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "buildkite-mcp": {
      "type": "remote",
      "url": "https://mcp.buildkite.com/mcp",
      "enabled": false
    },
    "web-forager": {
      "type": "local",
      "command": [
        "web-forager",
        "serve"
      ],
      "enabled": true
    },
    "github-mcp": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "dhi.io/github-mcp"
      ],
      "enabled": false,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "stackoverflow-mcp": {
      "type": "local",
      "command": [
        "stackoverflow-mcp"
      ],
      "environment": {
        "STACK_EXCHANGE_API_KEY": "{env:STACK_EXCHANGE_API_KEY}"
      },
      "enabled": false
    },
    "framelink-figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "environment": {
        "FIGMA_API_KEY": "{env:FIGMA_API_KEY}"
      },
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics"
      ],
      "enabled": true
    },
    "mcp-ocr": {
      "type": "local",
      "command": [
        "mcp-ocr"
      ],
      "enabled": true
    },
    "atlassian-mcp": {
      "type": "local",
      "command": [
        "mcp-atlassian"
      ],
      "environment": {
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USERNAME": "{env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
        "CONFLUENCE_USERNAME": "{env:CONFLUENCE_USERNAME}",
        "CONFLUENCE_API_TOKEN": "{env:CONFLUENCE_API_TOKEN}"
      },
      "enabled": false
    },
    "sonarqube-mcp": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--pull=always",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "{env:SONARQUBE_URL}"
      },
      "enabled": false
    }
  }
}
