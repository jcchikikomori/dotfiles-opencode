#!/bin/sh

set -eu

# dotfiles-opencode — install opencode AI coding agent and its MCP dependencies
# https://opencode.ai/docs

# Source .profile.local for environment variables (MCP tokens, etc.)
if [ -f "$HOME/.profile.local" ]; then
    . "$HOME/.profile.local"
fi

OPENCODE_CONFIG="$HOME/.config/opencode/opencode.jsonc"
OPENCODE_ENV="$HOME/.config/opencode/.env"

# Determine dotfiles path for shared MCP registry
if [ -n "${DOTFILES_PATH:-}" ]; then
    DOTFILES_DIR="$DOTFILES_PATH"
elif [ -d "$HOME/.dotfiles" ]; then
    DOTFILES_DIR="$HOME/.dotfiles"
else
    DOTFILES_DIR="$(dirname "$(dirname "$(dirname "$(dirname "$(dirname "$(cd -- "$(dirname -- "$0")" && pwd)")")")")")"
fi

# Check for local mcps.json first, then fall back to shared registry
# Script is at: linux/opencode/.local/bin/org.jcchikikomori.agentic.opencode/bin/dotfiles-opencode
# mcps.json is at: linux/opencode/mcps.json (4 levels up from script)
SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
OPENCODE_DIR="$(dirname "$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")")"
LOCAL_MCPS_FILE="${OPENCODE_DIR}/mcps.json"
SHARED_MCPS_FILE="${DOTFILES_DIR}/shared/ai-agents/mcps.json"

# Use local mcps.json if it exists, otherwise use shared
if [ -f "$LOCAL_MCPS_FILE" ]; then
    MCPS_FILE="$LOCAL_MCPS_FILE"
else
    MCPS_FILE="$SHARED_MCPS_FILE"
fi

_is_installed() {
    command -v opencode > /dev/null 2>&1
}

_detect_distro() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "${ID:-unknown}"
    else
        echo "unknown"
    fi
}

_is_termux() {
    [ -n "${PREFIX:-}" ] && echo "$PREFIX" | grep -q "com.termux"
}

# ─── JSON helpers ─────────────────────────────────────────────────────────────

_json_tool() {
    if command -v jq > /dev/null 2>&1; then
        echo "jq"
    elif command -v python3 > /dev/null 2>&1; then
        echo "python3"
    else
        echo "none"
    fi
}

# Extract all local MCP entries as lines: "<name> <command0> <env_keys...>"
# Output format (one line per MCP):
#   name=<name> type=<type> cmd0=<command[0]> cmd1=<command[1]> env=<KEY1,KEY2,...>
_parse_mcps() {
    local config="$1"
    local tool
    tool=$(_json_tool)

    case "$tool" in
        jq)
            grep -v '^\s*//' "$config" | jq -r '
              .mcp // {} | to_entries[] |
              "name=\(.key) type=\(.value.type // "local") cmd0=\(.value.command[0] // "") cmd1=\(.value.command[1] // "") env=\(.value.environment // {} | keys | join(","))"
            ' 2>/dev/null || true
            ;;
        python3)
            grep -v '^\s*//' "$config" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for name, entry in (data.get('mcp') or {}).items():
    t = entry.get('type', 'local')
    cmd = entry.get('command') or []
    cmd0 = cmd[0] if len(cmd) > 0 else ''
    cmd1 = cmd[1] if len(cmd) > 1 else ''
    env_keys = ','.join((entry.get('environment') or {}).keys())
    print(f'name={name} type={t} cmd0={cmd0} cmd1={cmd1} env={env_keys}')
" 2>/dev/null || true
            ;;
        *)
            echo ""
            ;;
    esac
}

# Read a value from the .env file (KEY=value lines)
_env_file_get() {
    local key="$1"
    local envfile="${2:-$OPENCODE_ENV}"
    if [ ! -f "$envfile" ]; then
        echo ""
        return
    fi
    # grep for KEY= line, strip comments and the key prefix
    grep -m1 "^${key}=" "$envfile" 2>/dev/null | cut -d= -f2- || echo ""
}

# ─── New JSON-based MCP parser ────────────────────────────────────────────────
# Parse MCPs from mcps.json format (shared registry)
# Output format (one line per MCP):
#   name=<name> type=<installMethod> cmd0=<command/binary> cmd1=<args[0]> env=<KEY1,KEY2,...>
_parse_mcps_from_json() {
    local json_file="$1"
    local tool
    tool=$(_json_tool)

    [ ! -f "$json_file" ] && return 0

    case "$tool" in
        jq)
            jq -r '.mcpServers // {} | to_entries[] |
              . as $entry |
              ($entry.value.type // "stdio") as $type |
              (if $type == "http" then "remote"
               elif ($entry.value.command // "") != "" then ($entry.value.command // "")
               else "" end) as $cmd0 |
              (($entry.value.args // [])[0] // "") as $cmd1 |
              (($entry.value.env // []) | join(",")) as $env |
              "name=\($entry.key) type=\($entry.value.installMethod // "pipx") cmd0=\($cmd0) cmd1=\($cmd1) env=\($env)"
            ' "$json_file" 2>/dev/null || true
            ;;
        python3)
            python3 -c "
import json
try:
    with open('$json_file') as f:
        data = json.load(f)
    for name, mcp in (data.get('mcpServers') or {}).items():
        mcp_type = mcp.get('type', 'stdio')
        if mcp_type == 'http':
            cmd0 = 'remote'
        elif mcp.get('command'):
            cmd0 = mcp['command']
        else:
            cmd0 = ''
        cmd1 = (mcp.get('args') or [''])[0] if mcp.get('args') else ''
        env_keys = ','.join(mcp.get('env') or [])
        install_method = mcp.get('installMethod', 'pipx')
        print(f'name={name} type={install_method} cmd0={cmd0} cmd1={cmd1} env={env_keys}')
except Exception:
    pass
" 2>/dev/null || true
            ;;
        *)
            echo ""
            ;;
    esac
}

# ─── MCP helpers ──────────────────────────────────────────────────────────────

# Print ENV key status for an MCP (reads from .env file)
_report_env() {
    mcp_name="$1"
    env_keys="$2"
    [ -z "$env_keys" ] && return

    echo "            ENV for $mcp_name:"
    # env_keys is comma-separated
    old_ifs="$IFS"
    IFS=","
    for key in $env_keys; do
        IFS="$old_ifs"
        [ -z "$key" ] && continue
        # Check shell environment first, then .env file
        val=""
        eval "val=\${${key}:-}"
        if [ -z "$val" ]; then
            val=$(_env_file_get "$key")
        fi
        if [ -n "$val" ]; then
            echo "              $key  → set ✓"
        else
            echo "              $key  → NOT SET  ← add to $OPENCODE_ENV"
        fi
        IFS=","
    done
    IFS="$old_ifs"
}

# ─── MCP install: classify and act on a single parsed line ───────────────────

# Process one MCP line (from _parse_mcps output) and install/report as needed.
# Usage: _process_mcp_line "<line>"
# Prints label lines to stdout. Returns 0 always.
_process_mcp_line() {
    line="$1"
    [ -z "$line" ] && return 0

    # Extract fields
    mcp_name=$(echo "$line" | sed 's/.*name=\([^ ]*\).*/\1/')
    mcp_type=$(echo "$line" | sed 's/.*type=\([^ ]*\).*/\1/')
    mcp_cmd0=$(echo "$line" | sed 's/.*cmd0=\([^ ]*\).*/\1/')
    mcp_cmd1=$(echo "$line" | sed 's/.*cmd1=\([^ ]*\).*/\1/')
    mcp_env=$(echo "$line" | sed 's/.*env=\([^ ]*\).*/\1/')

    # remote MCP — no binary needed
    if [ "$mcp_type" = "remote" ]; then
        echo "  [skip]    $mcp_name  (remote URL — no install needed)"
        return 0
    fi
    
    # http install method — no binary needed
    if [ "$mcp_type" = "http" ]; then
        echo "  [skip]    $mcp_name  (HTTP endpoint — no install needed)"
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    # No command at all — skip
    if [ -z "$mcp_cmd0" ]; then
        echo "  [skip]    $mcp_name  (no command defined)"
        return 0
    fi
    
    # cmd0 is "remote" placeholder for HTTP — skip
    if [ "$mcp_cmd0" = "remote" ]; then
        echo "  [skip]    $mcp_name  (HTTP endpoint — no install needed)"
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    # npx-based — auto-fetches at runtime
    if [ "$mcp_cmd0" = "npx" ]; then
        if command -v npx > /dev/null 2>&1; then
            echo "  [npx]     $mcp_name  (auto-fetched via npx — OK)"
        else
            echo "  [warn]    $mcp_name  needs npx — install Node.js/npm first"
        fi
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    # uvx-based — auto-fetches at runtime
    if [ "$mcp_cmd0" = "uvx" ]; then
        if command -v uvx > /dev/null 2>&1; then
            echo "  [uvx]     $mcp_name  (auto-fetched via uvx — OK)"
        else
            echo "  [warn]    $mcp_name  needs uvx — install uv first"
        fi
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    # docker-based — can't install the image here, just notice
    if [ "$mcp_cmd0" = "docker" ]; then
        if command -v docker > /dev/null 2>&1; then
            echo "  [docker]  $mcp_name  (Docker image — pull manually if needed)"
            echo "            Command: docker $mcp_cmd1 ..."
        else
            echo "  [warn]    $mcp_name  needs Docker — install Docker first"
        fi
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    # pipx candidate — binary must be on PATH
    if command -v "$mcp_cmd0" > /dev/null 2>&1; then
        echo "  [ok]      $mcp_name  ($mcp_cmd0 already in PATH)"
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    # Not found — install via pipx using the binary name as the package name
    echo "  [pipx]    $mcp_name  installing '$mcp_cmd0' via pipx..."
    if pipx install "$mcp_cmd0" 2>&1 | sed 's/^/              /'; then
        echo "  [done]    $mcp_name  installed OK"
    else
        echo "  [fail]    $mcp_name  pipx install '$mcp_cmd0' failed"
        echo "            If the package name differs from the binary, install manually:"
        echo "            pipx install <correct-package-name>"
    fi
    _report_env "$mcp_name" "$mcp_env"
}

# ─── MCP dependency installer ─────────────────────────────────────────────────

do_install_mcps() {
    echo ""
    echo "[dotfiles-opencode] Installing MCP dependencies..."

    # Guard: Termux not supported for pipx MCPs
    if _is_termux; then
        echo "[dotfiles-opencode] Termux detected — skipping MCP dependency install."
        echo "  Install MCP packages manually with: pip install <package>"
        return
    fi

    # Guard: need a JSON tool
    tool=$(_json_tool)
    if [ "$tool" = "none" ]; then
        echo "[dotfiles-opencode] Neither jq nor python3 found — cannot parse configs."
        echo "  Install jq (recommended) or python3, then re-run."
        return 1
    fi

    # Guard: pipx required for local binary MCPs
    if ! command -v pipx > /dev/null 2>&1; then
        echo "[dotfiles-opencode] pipx not found."
        echo "  Install it with:  pip install --user pipx  or  brew install pipx"
        echo "  Then re-run:  dotfiles-opencode install-mcps"
        return 1
    fi

    # Determine which config source to use
    if [ -f "$MCPS_FILE" ]; then
        # Use new JSON-based registry
        echo ""
        echo "  Using MCP registry: $MCPS_FILE"
        echo ""
        
        global_parse_tmp=$(mktemp)
        _parse_mcps_from_json "$MCPS_FILE" > "$global_parse_tmp"
        
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            _process_mcp_line "$line"
        done < "$global_parse_tmp"
        
        rm -f "$global_parse_tmp"
    elif [ -f "$OPENCODE_CONFIG" ]; then
        # Fallback to old opencode.jsonc format
        echo ""
        echo "  Parsing $OPENCODE_CONFIG ..."
        echo ""

        # Cache global parse output to a temp file so we can:
        #   (a) iterate without a pipeline subshell, and
        #   (b) re-use for project-config lookups below.
        global_parse_tmp=$(mktemp)
        _parse_mcps "$OPENCODE_CONFIG" > "$global_parse_tmp"

        # ── Phase 1: global config ──────────────────────────────────────────────

        while IFS= read -r line; do
            [ -z "$line" ] && continue
            _process_mcp_line "$line"
        done < "$global_parse_tmp"

        # ── Phase 2: project config ─────────────────────────────────────────────

        project_config="$PWD/.opencode/opencode.jsonc"

        if [ -f "$project_config" ]; then
            echo ""
            echo "  Scanning project config: $project_config ..."
            echo ""

            project_parse_tmp=$(mktemp)
            _parse_mcps "$project_config" > "$project_parse_tmp"

            while IFS= read -r pline; do
                [ -z "$pline" ] && continue

                # Extract fields from project MCP entry
                p_name=$(echo "$pline" | sed 's/.*name=\([^ ]*\).*/\1/')
                p_cmd0=$(echo "$pline" | sed 's/.*cmd0=\([^ ]*\).*/\1/')
                p_env=$(echo "$pline" | sed 's/.*env=\([^ ]*\).*/\1/')

                # If cmd0 is empty, look up in global config by name
                resolved_line="$pline"
                resolved_cmd0="$p_cmd0"
                resolved_env="$p_env"
                if [ -z "$p_cmd0" ]; then
                    global_line=$(grep "^name=${p_name} " "$global_parse_tmp" || true)
                    if [ -z "$global_line" ]; then
                        echo "  [skip]    $p_name  (no command — define in global config)"
                        continue
                    fi
                    resolved_line="$global_line"
                    resolved_cmd0=$(echo "$global_line" | sed 's/.*cmd0=\([^ ]*\).*/\1/')
                    # Merge env: prefer global env if project env is empty
                    if [ -z "$resolved_env" ]; then
                        resolved_env=$(echo "$global_line" | sed 's/.*env=\([^ ]*\).*/\1/')
                    fi
                    # Rebuild the line with the merged env so _process_mcp_line sees it
                    resolved_line=$(echo "$resolved_line" | sed "s/ env=[^ ]*/ env=${resolved_env}/")
                fi

                # Check if this cmd0 is already covered by the global phase
                global_has=$(grep " cmd0=${resolved_cmd0} " "$global_parse_tmp" || true)
                if [ -n "$global_has" ]; then
                    echo "  [ok]      $p_name  (covered by global config)"
                    # Still report env so missing keys are surfaced
                    _report_env "$p_name" "$resolved_env"
                    continue
                fi

                # Truly project-unique MCP — process like global phase
                _process_mcp_line "$resolved_line"

            done < "$project_parse_tmp"

            rm -f "$project_parse_tmp"
        fi

        rm -f "$global_parse_tmp"
    else
        echo "[dotfiles-opencode] No MCP config found"
        echo "  Expected: $MCPS_FILE or $OPENCODE_CONFIG"
        return 1
    fi

    echo ""
    echo "[dotfiles-opencode] MCP dependency check complete."
    echo ""
    echo "  Next steps:"
    echo "  1. Fill in missing ENV values in $OPENCODE_ENV"
    echo "  2. Enable desired MCPs in $OPENCODE_CONFIG"
    echo "     or run: dotfiles-opencode-wizard → Enable / Disable MCP"
    echo ""
}

# ─── opencode installer ───────────────────────────────────────────────────────

do_install() {
    if _is_installed; then
        echo "[dotfiles-opencode] opencode is already installed: $(opencode --version 2>/dev/null || true)"
    else
        DISTRO=$(_detect_distro)

        case "$DISTRO" in
            arch | manjaro)
                if command -v yay > /dev/null 2>&1; then
                    echo "[dotfiles-opencode] Installing opencode via yay (AUR)..."
                    yay -S --noconfirm opencode-bin
                else
                    echo "[dotfiles-opencode] yay not found. Installing opencode via install script..."
                    XDG_BIN_DIR="$HOME/.local/bin" curl -fsSL https://opencode.ai/install | bash
                fi
                ;;
            *)
                echo "[dotfiles-opencode] Installing opencode via install script..."
                XDG_BIN_DIR="$HOME/.local/bin" curl -fsSL https://opencode.ai/install | bash
                ;;
        esac

        echo ""
        echo "[dotfiles-opencode] Installation complete."
    fi

    # Copy env template if .env doesn't exist
    ENV_EXAMPLE="$HOME/.config/opencode/.env.example"
    ENV_FILE="$HOME/.config/opencode/.env"
    if [ -f "$ENV_EXAMPLE" ] && [ ! -f "$ENV_FILE" ]; then
        cp "$ENV_EXAMPLE" "$ENV_FILE"
        echo "[dotfiles-opencode] Created $ENV_FILE from template."
        echo "  Edit it to add your MCP tokens (GITHUB_PERSONAL_ACCESS_TOKEN, etc.)"
    fi

    # Option B: always chain into MCP dependency install
    do_install_mcps

    # ── Install OpenAgentsControl ───────────────────────────────────────────────
    do_install_oac

    echo ""
    echo "  Next steps:"
    echo "  1. Run: opencode"
    echo "  2. Inside opencode, run: /connect"
    echo "  3. Select 'GitHub Copilot' and follow the device code flow."
    echo "  4. Run: /models  to pick your preferred model."
    echo ""
    echo "  To add MCPs or create agents, run: dotfiles-opencode-wizard"
    echo ""
}

do_update() {
    if ! _is_installed; then
        echo "[dotfiles-opencode] opencode not installed — run with 'install' first."
        exit 1
    fi
    echo "[dotfiles-opencode] Updating opencode..."
    DISTRO=$(_detect_distro)
    case "$DISTRO" in
        arch | manjaro)
            if command -v yay > /dev/null 2>&1; then
                yay -S --noconfirm opencode-bin
            else
                XDG_BIN_DIR="$HOME/.local/bin" curl -fsSL https://opencode.ai/install | bash
            fi
            ;;
        *)
            XDG_BIN_DIR="$HOME/.local/bin" curl -fsSL https://opencode.ai/install | bash
            ;;
    esac
    echo "[dotfiles-opencode] Done: $(opencode --version 2>/dev/null || true)"
}

# ─── OpenAgentsControl installer ───────────────────────────────────────────────

do_install_oac() {
    echo ""
    echo "[dotfiles-opencode] Installing OpenAgentsControl (OAC)..."
    if curl -fsSL https://raw.githubusercontent.com/darrenhinde/OpenAgentsControl/main/install.sh | bash -s developer 2>&1 | sed 's/^/        /'; then
        echo "        [done] OpenAgentsControl installed OK"
        echo ""
        echo "  Start with: opencode --agent OpenAgent"
    else
        echo "        [warn] OpenAgentsControl install may have failed or is already installed"
    fi
}

# ─── oh-my-opencode-slim config generator ──────────────────────────────────────

do_install_slim_config() {
    echo ""
    echo "[dotfiles-opencode] Generating oh-my-opencode-slim configuration..."
    
    # Guard: Node.js required
    if ! command -v node > /dev/null 2>&1; then
        echo "[dotfiles-opencode] Node.js not found — install it first."
        return 1
    fi
    
    # Guard: opencode must be installed
    if ! _is_installed; then
        echo "[dotfiles-opencode] opencode not installed — run 'dotfiles-opencode install' first."
        return 1
    fi
    
    # Guard: opencode.jsonc must exist
    if [ ! -f "$OPENCODE_CONFIG" ]; then
        echo "[dotfiles-opencode] Config not found at $OPENCODE_CONFIG"
        return 1
    fi
    
    echo "  Detecting available providers..."
    echo "  Fetching model list..."
    echo ""
    
    # Path to the script
    SCRIPT_DIR="$HOME/.dotfiles/linux/opencode/.config/opencode/scripts/generate-slim-config"
    
    # Check if script exists
    if [ ! -d "$SCRIPT_DIR" ]; then
        echo "[dotfiles-opencode] generate-slim-config not found at $SCRIPT_DIR"
        echo "  Run: cd $SCRIPT_DIR && npm install && npm run build"
        return 1
    fi
    
    # Execute generator (pass through all arguments)
    if cd "$SCRIPT_DIR" && node dist/index.js "$@" 2>&1 | sed 's/^/        /'; then
        echo ""
        echo "  [done] Configuration generated successfully"
        echo ""
        echo "  Test with: opencode --agent orchestrator"
        echo "  Or use any agent: council, explorer, oracle, etc."
        echo ""
        echo "  To switch presets, edit ~/.config/opencode/oh-my-opencode-slim.jsonc"
        echo "  Or set: export OH_MY_OPENCODE_SLIM_PRESET=<preset-name>"
    else
        echo ""
        echo "  [fail] Configuration generation failed"
        echo "  Try: dotfiles-opencode install-slim-config --verbose"
        return 1
    fi
}

# ─── Cache management ──────────────────────────────────────────────────────────

do_clear_cache() {
    OPENCODE_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/opencode"
    
    echo ""
    echo "[dotfiles-opencode] Clearing OpenCode cache..."
    echo ""
    
    if [ -d "$OPENCODE_CACHE" ]; then
        echo "  Cache location: $OPENCODE_CACHE"
        
        # Show cache size before clearing
        if command -v du > /dev/null 2>&1; then
            cache_size=$(du -sh "$OPENCODE_CACHE" 2>/dev/null | cut -f1)
            echo "  Current size:   $cache_size"
        fi
        
        echo ""
        echo "  Removing cache directory..."
        rm -rf "$OPENCODE_CACHE"
        
        if [ ! -d "$OPENCODE_CACHE" ]; then
            echo "  [done] Cache cleared successfully"
        else
            echo "  [warn] Cache directory still exists — may need manual removal"
        fi
    else
        echo "  [skip] No cache found at $OPENCODE_CACHE"
    fi
    
    echo ""
    echo "  When to clear cache:"
    echo "  - After changing model configuration"
    echo "  - When troubleshooting tool/skill calling issues"
    echo "  - After updating opencode or MCP servers"
    echo "  - When experiencing unexpected behavior"
    echo ""
}

# ─── Instruction generator ────────────────────────────────────────────────────

do_generate_instructions() {
    echo ""
    echo "[dotfiles-opencode] Generating AGENTS.md from shared instructions..."
    
    # Determine dotfiles path
    if [ -n "${DOTFILES_PATH:-}" ]; then
        DOTFILES_DIR="$DOTFILES_PATH"
    elif [ -d "$HOME/.dotfiles" ]; then
        DOTFILES_DIR="$HOME/.dotfiles"
    else
        echo "[dotfiles-opencode] Cannot locate dotfiles directory"
        echo "  Set DOTFILES_PATH or ensure ~/.dotfiles exists"
        return 1
    fi
    
    SHARED_INSTRUCTIONS="${DOTFILES_DIR}/shared/ai-agents/instructions/global.md"
    OUTPUT_FILE="${OPENCODE_CONFIG%/*}/AGENTS.md"
    
    # Check if source exists
    if [ ! -f "$SHARED_INSTRUCTIONS" ]; then
        echo "[dotfiles-opencode] Shared instructions not found: $SHARED_INSTRUCTIONS"
        return 1
    fi
    
    # Create config directory if needed
    mkdir -p "$(dirname "$OUTPUT_FILE")"
    
    # Copy instructions
    cp "$SHARED_INSTRUCTIONS" "$OUTPUT_FILE"
    
    echo "  [done] Generated: $OUTPUT_FILE"
    echo "  Source: $SHARED_INSTRUCTIONS"
    echo ""
    echo "  This file is auto-generated. Edit the shared source instead:"
    echo "  $SHARED_INSTRUCTIONS"
    echo ""
}

case "${1:-}" in
    install)             do_install ;;
    update)              do_update ;;
    install-mcps)        do_install_mcps ;;
    install-oac)         do_install_oac ;;
    install-slim-config) shift; do_install_slim_config "$@" ;;
    wizard)              dotfiles-opencode-wizard ;;
    clear-cache)         do_clear_cache ;;
    generate-instructions) do_generate_instructions ;;
    *)
        echo "Usage: dotfiles-opencode {install|update|install-mcps|install-oac|install-slim-config|wizard|clear-cache|generate-instructions}"
        echo "  install:               Install opencode and all MCP dependencies"
        echo "  update:                Update opencode to the latest version"
        echo "  install-mcps:          Install/check MCP dependencies only (re-run anytime)"
        echo "  install-oac:           Install OpenAgentsControl (OAC) separately"
        echo "  install-slim-config:   Generate oh-my-opencode-slim configuration with auto-detected models"
        echo "                         Flags: --interactive, --prefer <provider>, --dry-run, --reset, --verbose"
        echo "  wizard:                Launch the opencode setup wizard"
        echo "  clear-cache:           Clear OpenCode cache (useful after config/model changes)"
        echo "  generate-instructions: Generate AGENTS.md from shared instructions"
        exit 1
        ;;
esac
