#!/bin/sh
# dotfiles-opencode-env — Env loader wrapper for opencode
# Load global + project .env files, then exec opencode

set -eu

# Guard against recursion
if [ -n "${_DOTFILES_OPENCODE_ENV_LOADED:-}" ]; then
    exec command opencode "$@"
fi

# Load global .env
if [ -f "$HOME/.config/opencode/.env" ]; then
    set -a
    . "$HOME/.config/opencode/.env"
    set +a
fi

# Walk up from $PWD to find nearest .opencode/.env
_dir="$PWD"
while [ -n "$_dir" ]; do
    if [ -f "$_dir/.opencode/.env" ]; then
        set -a
        . "$_dir/.opencode/.env"
        set +a
        break
    fi
    _dir="${_dir%/*}"
done

# Debug output
if [ -n "${_DOTFILES_OPENCODE_ENV_DEBUG:-}" ]; then
    echo "[dotfiles-opencode-env] loaded: $HOME/.config/opencode/.env"
    if [ -n "${_DOTFILES_OPENCODE_ENV_PROJECT:-}" ]; then
        echo "[dotfiles-opencode-env] loaded: $_DOTFILES_OPENCODE_ENV_PROJECT/.opencode/.env"
    fi
    echo "[dotfiles-opencode-env] exec: command opencode $@"
fi

# Recursion guard + exec
export _DOTFILES_OPENCODE_ENV_LOADED=1
exec command opencode "$@"
