#!/bin/bash

set -euo pipefail

# install-oac — Standalone OpenAgentsControl (OAC) installer
# Part of dotfiles-opencode: https://github.com/jcchikikomori/dotfiles-opencode

VERSION="1.0.0"
OAC_REPO="https://raw.githubusercontent.com/darrenhinde/OpenAgentsControl/main"
OAC_INSTALL_SCRIPT="${OAC_REPO}/install.sh"
OAC_TARGET="$HOME/.opencode"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ─── Helper Functions ─────────────────────────────────────────────────────────

_print_header() {
    echo ""
    echo -e "${BLUE}====================================${NC}"
    echo -e "${BLUE}  OpenAgentsControl Installer${NC}"
    echo -e "${BLUE}  Version: $VERSION${NC}"
    echo -e "${BLUE}====================================${NC}"
    echo ""
}

_print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

_print_error() {
    echo -e "${RED}✗${NC} $1"
}

_print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

_print_info() {
    echo -e "${BLUE}→${NC} $1"
}

_check_dependencies() {
    local missing=()

    if ! command -v curl &> /dev/null; then
        missing+=("curl")
    fi

    if ! command -v bash &> /dev/null; then
        missing+=("bash")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        _print_error "Missing required dependencies: ${missing[*]}"
        echo "  Please install them first, then retry."
        return 1
    fi

    return 0
}

_is_oac_installed() {
    [ -d "$OAC_TARGET" ] && [ -f "$OAC_TARGET/README.md" ]
}

_get_oac_version() {
    if [ -f "$OAC_TARGET/VERSION" ]; then
        cat "$OAC_TARGET/VERSION"
    elif [ -f "$OAC_TARGET/README.md" ]; then
        # Try to extract version from README
        grep -m1 "Version:" "$OAC_TARGET/README.md" | cut -d':' -f2 | tr -d ' ' || echo "unknown"
    else
        echo "unknown"
    fi
}

_count_agents() {
    if [ -d "$OAC_TARGET/agents" ]; then
        find "$OAC_TARGET/agents" -name "*.md" -type f | wc -l
    else
        echo "0"
    fi
}

_count_context_files() {
    if [ -d "$OAC_TARGET/context" ]; then
        find "$OAC_TARGET/context" -name "*.md" -type f | wc -l
    else
        echo "0"
    fi
}

_count_commands() {
    if [ -d "$OAC_TARGET/commands" ]; then
        find "$OAC_TARGET/commands" -name "*.sh" -type f | wc -l
    else
        echo "0"
    fi
}

# ─── Main Actions ─────────────────────────────────────────────────────────────

do_install() {
    _print_header
    _print_info "Installing OpenAgentsControl..."
    echo ""

    # Check dependencies
    if ! _check_dependencies; then
        exit 1
    fi

    # Check if already installed
    if _is_oac_installed; then
        _print_warning "OpenAgentsControl is already installed at $OAC_TARGET"
        local version
        version=$(_get_oac_version)
        echo "  Current version: $version"
        echo ""
        printf "  Reinstall/update? [y/N]: "
        read -r response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            _print_info "Installation cancelled."
            exit 0
        fi
        echo ""
        _print_info "Proceeding with reinstall/update..."
    fi

    # Download and execute installer
    _print_info "Downloading OAC installer from GitHub..."
    echo ""

    if curl -fsSL "$OAC_INSTALL_SCRIPT" | bash -s developer; then
        echo ""
        _print_success "OpenAgentsControl installed successfully!"
        echo ""
        do_status
    else
        echo ""
        _print_error "Installation failed."
        _print_info "This may be normal if OAC is already installed."
        _print_info "Run: $0 status  to verify installation"
        exit 1
    fi
}

do_update() {
    _print_header

    if ! _is_oac_installed; then
        _print_error "OpenAgentsControl is not installed."
        _print_info "Run: $0 install"
        exit 1
    fi

    _print_info "Updating OpenAgentsControl..."
    echo ""
    _print_info "Downloading latest version from GitHub..."
    echo ""

    if curl -fsSL "$OAC_INSTALL_SCRIPT" | bash -s developer; then
        echo ""
        _print_success "OpenAgentsControl updated successfully!"
        echo ""
        do_status
    else
        echo ""
        _print_error "Update failed."
        _print_info "Your current installation remains unchanged."
        exit 1
    fi
}

do_status() {
    _print_header

    if ! _is_oac_installed; then
        _print_error "OpenAgentsControl is not installed."
        echo ""
        echo "  Install with: $0 install"
        exit 1
    fi

    _print_success "OpenAgentsControl is installed"
    echo ""

    local version agent_count context_count command_count
    version=$(_get_oac_version)
    agent_count=$(_count_agents)
    context_count=$(_count_context_files)
    command_count=$(_count_commands)

    echo "  Installation Details:"
    echo "  ────────────────────────────────────"
    echo "  Location:       $OAC_TARGET"
    echo "  Version:        $version"
    echo "  Agents:         $agent_count"
    echo "  Context Files:  $context_count"
    echo "  Commands:       $command_count"
    echo ""

    if [ "$agent_count" -gt 0 ]; then
        echo "  Main Agents:"
        echo "  ────────────────────────────────────"
        if [ -f "$OAC_TARGET/agents/OpenAgent.md" ]; then
            _print_success "OpenAgent (general purpose)"
        fi
        if [ -f "$OAC_TARGET/agents/OpenCoder.md" ]; then
            _print_success "OpenCoder (production code)"
        fi
        echo ""

        echo "  Available Subagents:"
        echo "  ────────────────────────────────────"
        for agent in "$OAC_TARGET/agents"/*.md; do
            [ -f "$agent" ] || continue
            agent_name=$(basename "$agent" .md)
            # Skip main agents
            [[ "$agent_name" == "OpenAgent" ]] && continue
            [[ "$agent_name" == "OpenCoder" ]] && continue
            echo "    • $agent_name"
        done
        echo ""
    fi

    echo "  Quick Start:"
    echo "  ────────────────────────────────────"
    echo "    opencode --agent OpenAgent     # General purpose"
    echo "    opencode --agent OpenCoder     # Production code"
    echo ""
    echo "  Available Commands (in opencode session):"
    echo "  ────────────────────────────────────"
    if [ "$command_count" -gt 0 ]; then
        for cmd in "$OAC_TARGET/commands"/*.sh; do
            [ -f "$cmd" ] || continue
            cmd_name=$(basename "$cmd" .sh)
            echo "    /$cmd_name"
        done
    else
        echo "    (No commands found)"
    fi
    echo ""
}

do_uninstall() {
    _print_header

    if ! _is_oac_installed; then
        _print_warning "OpenAgentsControl is not installed."
        exit 0
    fi

    _print_warning "This will remove OpenAgentsControl from your system."
    echo "  Location: $OAC_TARGET"
    echo ""
    printf "  Are you sure? [y/N]: "
    read -r response

    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        _print_info "Uninstall cancelled."
        exit 0
    fi

    echo ""
    _print_info "Removing $OAC_TARGET ..."

    if rm -rf "$OAC_TARGET"; then
        _print_success "OpenAgentsControl uninstalled successfully."
    else
        _print_error "Failed to remove $OAC_TARGET"
        _print_info "You may need to remove it manually with:"
        echo "  rm -rf $OAC_TARGET"
        exit 1
    fi
}

do_verify() {
    _print_header
    _print_info "Verifying OpenAgentsControl installation..."
    echo ""

    local errors=0

    # Check main directory
    if [ -d "$OAC_TARGET" ]; then
        _print_success "Installation directory exists: $OAC_TARGET"
    else
        _print_error "Installation directory missing: $OAC_TARGET"
        ((errors++))
    fi

    # Check agents directory
    if [ -d "$OAC_TARGET/agents" ]; then
        _print_success "Agents directory exists"

        # Check main agents
        if [ -f "$OAC_TARGET/agents/OpenAgent.md" ]; then
            _print_success "OpenAgent found"
        else
            _print_error "OpenAgent.md missing"
            ((errors++))
        fi

        if [ -f "$OAC_TARGET/agents/OpenCoder.md" ]; then
            _print_success "OpenCoder found"
        else
            _print_error "OpenCoder.md missing"
            ((errors++))
        fi
    else
        _print_error "Agents directory missing"
        ((errors++))
    fi

    # Check context directory
    if [ -d "$OAC_TARGET/context" ]; then
        _print_success "Context directory exists"
    else
        _print_warning "Context directory missing (optional)"
    fi

    # Check commands directory
    if [ -d "$OAC_TARGET/commands" ]; then
        _print_success "Commands directory exists"
    else
        _print_warning "Commands directory missing (optional)"
    fi

    echo ""
    if [ $errors -eq 0 ]; then
        _print_success "Verification passed! OAC is properly installed."
    else
        _print_error "Verification failed with $errors error(s)."
        _print_info "Try reinstalling with: $0 install"
        exit 1
    fi
}

show_help() {
    cat <<EOF
Usage: $0 <command>

Commands:
  install     Install OpenAgentsControl (prompts before overwriting)
  update      Update OAC to the latest version
  status      Show installation status and agent details
  verify      Verify OAC installation integrity
  uninstall   Remove OpenAgentsControl from your system
  help        Show this help message

Examples:
  $0 install              # First-time installation
  $0 status               # Check what's installed
  $0 update               # Get latest version
  $0 verify               # Check installation integrity

More info: https://github.com/darrenhinde/OpenAgentsControl
EOF
}

# ─── Main Entry Point ─────────────────────────────────────────────────────────

case "${1:-help}" in
    install)     do_install ;;
    update)      do_update ;;
    status)      do_status ;;
    verify)      do_verify ;;
    uninstall)   do_uninstall ;;
    help|--help|-h) show_help ;;
    *)
        _print_error "Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
